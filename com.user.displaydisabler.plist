<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.displaydisabler</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/Users/admin/bin/auto_disable_builtin.sh</string>
    </array>
    
    <key>RunAtLoad</key>
    <true/>
    
    <key>StandardOutPath</key>
    <string>/tmp/displaydisabler.log</string>
    
    <key>StandardErrorPath</key>
    <string>/tmp/displaydisabler.error.log</string>
</dict>
</plist>
